<script>
import { Fancybox } from "@fancyapps/ui";
import "@fancyapps/ui/dist/fancybox/fancybox.css";

function initFancybox() {
  Fancybox.close();
  
  Fancybox.bind(".custom-md img, #post-cover img, .moment-images img" as any, {
    groupAll: true,
    Thumbs: {
      autoStart: true,
      showOnStart: "yes",
    },
    Toolbar: {
      display: {
        left: ["infobar"],
        middle: [
          "zoomIn",
          "zoomOut",
          "toggle1to1",
          "rotateCCW",
          "rotateCW",
          "flipX",
          "flipY",
        ],
        right: ["slideshow", "thumbs", "close"],
      },
    },
    animated: true,
    dragToClose: true,
    keyboard: {
      Escape: "close",
      Delete: "close",
      Backspace: "close",
      PageUp: "next",
      PageDown: "prev",
      ArrowUp: "next",
      ArrowDown: "prev",
      ArrowRight: "next",
      ArrowLeft: "prev",
    },
    fitToView: true,
    preload: 3,
    infinite: true,
    Panzoom: {
      maxScale: 3,
      minScale: 1,
    },
    Carousel: {
      transition: "slide",
      preload: 2,
    },
    caption: false
  });
  
  Fancybox.bind(".moment-images a[data-fancybox]" as any, {
    Thumbs: {
      autoStart: true,
      showOnStart: "yes",
    },
    Toolbar: {
      display: {
        left: ["infobar"],
        middle: [
          "zoomIn",
          "zoomOut",
          "toggle1to1",
          "rotateCCW",
          "rotateCW",
          "flipX",
          "flipY",
        ],
        right: ["slideshow", "thumbs", "close"],
      },
    },
    animated: true,
    dragToClose: true,
    keyboard: {
      Escape: "close",
      Delete: "close",
      Backspace: "close",
      PageUp: "next",
      PageDown: "prev",
      ArrowUp: "next",
      ArrowDown: "prev",
      ArrowRight: "next",
      ArrowLeft: "prev",
    },
    fitToView: true,
    preload: 3,
    infinite: true,
    Panzoom: {
      maxScale: 3,
      minScale: 1,
    },
    source: (el: any) => {
      return el.getAttribute("data-src") || el.getAttribute("href");
    },
    caption: false
  });
  
  Fancybox.bind("[data-fancybox]:not(.moment-images a)" as any, {
    Thumbs: {
      autoStart: true,
      showOnStart: "yes",
    },
    Toolbar: {
      display: {
        left: ["infobar"],
        middle: [
          "zoomIn",
          "zoomOut",
          "toggle1to1",
          "rotateCCW",
          "rotateCW",
          "flipX",
          "flipY",
        ],
        right: ["slideshow", "thumbs", "close"],
      },
    },
    animated: true,
    dragToClose: true,
    keyboard: {
      Escape: "close",
      Delete: "close",
      Backspace: "close",
      PageUp: "next",
      PageDown: "prev",
      ArrowUp: "next",
      ArrowDown: "prev",
      ArrowRight: "next",
      ArrowLeft: "prev",
    },
    fitToView: true,
    preload: 3,
    infinite: true,
    Panzoom: {
      maxScale: 3,
      minScale: 1,
    },
    caption: false
  });
}

const setup = () => {
  initFancybox();
  
  if (window.swup) {
    window.swup.hooks.on("page:view", () => {
      setTimeout(() => {
        initFancybox();
      }, 100);
    });
  }
}

if (window.swup) {
  setup()
} else {
  document.addEventListener("swup:enable", setup)
  
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFancybox);
  } else {
    initFancybox();
  }
}
</script>
