---
import type { CollectionEntry } from "astro:content";
import { getPostUrlBySlug } from "@utils/url-utils";
import PostCard from "@/components/content/PostCard.astro";
import { siteConfig } from "@/config";

const { page } = Astro.props;

let delay = 0;
const interval = 50;

// Type alias to avoid Fragment syntax issues
type PostEntry = CollectionEntry<"posts">;
---

<div
  id="post-list-container"
  class="transition flex flex-col gap-4 md:gap-4 mb-4"
  style="opacity: 0;"
  data-default-layout={siteConfig.postListLayout.defaultMode}
>
  {
    page.data.map((entry: PostEntry) => (
      <PostCard
        entry={entry}
        title={entry.data.title}
        tags={entry.data.tags}
        category={entry.data.category}
        published={entry.data.published}
        updated={entry.data.updated}
        url={getPostUrlBySlug(entry.slug)}
        image={entry.data.image}
        description={entry.data.description}
        draft={entry.data.draft}
        pinned={entry.data.pinned}
        class:list="onload-animation post-card-item"
        style={`animation-delay: calc(var(--content-delay) + ${delay++ * interval}ms);`}
      />
    ))
  }
</div>

<script>
  // Dynamic layout switching script
  function initLayout() {
    const postListContainer = document.getElementById("post-list-container");
    if (!postListContainer) return;

    // Check screen width
    const screenWidth = window.innerWidth;
    const isSmallScreen = screenWidth < 1200;

    // Read user preference from localStorage
    const savedLayout = localStorage.getItem("postListLayout");
    const defaultLayout =
      postListContainer.getAttribute("data-default-layout") || "list";
    let currentLayout = savedLayout || defaultLayout;

    // If screen width is less than 1200px, force list mode
    if (isSmallScreen) {
      currentLayout = "list";
    }

    // Apply layout
    updatePostListLayout(currentLayout);
  }

  function updatePostListLayout(layout: string) {
    const postListContainer = document.getElementById("post-list-container");
    if (!postListContainer) return;

    if (layout === "grid") {
      // Switch to grid mode
      postListContainer.className =
        "transition grid grid-cols-1 md:grid-cols-2 gap-4 mb-4 grid-mode";
    } else {
      // Switch to list mode
      postListContainer.className =
        "transition flex flex-col gap-4 md:gap-4 mb-4";
    }

    // Show container after layout applied
    postListContainer.style.opacity = "1";
  }

  // Initialize layout on page load
  document.addEventListener("DOMContentLoaded", function () {
    // Delay slightly to ensure DOM is fully loaded
    setTimeout(initLayout, 50);
  });

  // Initialize layout on page visibility change (handle page switch)
  document.addEventListener("visibilitychange", function () {
    if (!document.hidden) {
      setTimeout(initLayout, 100);
    }
  });

  // Listen for layout change events
  window.addEventListener("layoutChange", function (event: CustomEvent) {
    const newLayout = event.detail.layout;
    // Check screen width, force list mode if less than 1200px
    const screenWidth = window.innerWidth;
    const isSmallScreen = screenWidth < 1200;

    if (isSmallScreen) {
      updatePostListLayout("list");
    } else {
      updatePostListLayout(newLayout);
    }
  });

  // Listen for window resize
  let resizeTimeout;
  window.addEventListener("resize", function () {
    clearTimeout(resizeTimeout);
    resizeTimeout = setTimeout(function () {
      initLayout();
    }, 250);
  });

  // Listen for page navigation events (Astro client-side routing)
  document.addEventListener("astro:page-load", function () {
    setTimeout(initLayout, 50);
  });
  document.addEventListener("astro:after-swap", function () {
    setTimeout(initLayout, 50);
  });

  // Execute once immediately (handle page refresh)
  setTimeout(initLayout, 0);
</script>
